---
import app, { type RsvpResult } from "../server/api";

export const prerender = false;

const floatingPhotos = [
	{
		src: "/63452BC3-649E-4502-802D-3567FB557411.jpeg",
		width: 772,
		height: 1158,
		alt: "Summervilla photo 1",
	},
	{
		src: "/650E2217-BA0C-483D-9119-E60C408F9D38.jpeg",
		width: 1182,
		height: 1476,
		alt: "Summervilla photo 2",
	},
	{
		src: "/684A1E29-8B96-47AC-BC4F-5F3DC2B94C09.jpeg",
		width: 1200,
		height: 1765,
		alt: "Summervilla photo 3",
	},
	{
		src: "/849A2C0E-BD32-48E2-BB1E-301C2DAFAA46.jpeg",
		width: 1170,
		height: 1100,
		alt: "Summervilla photo 4",
	},
	{
		src: "/E5C1BF6E-10AB-40BC-B395-D5879475E077.jpeg",
		width: 854,
		height: 1200,
		alt: "Summervilla photo 5",
	},
	{
		src: "/ED5459DA-B09E-41E7-A628-5E4CF0C9F754.jpeg",
		width: 736,
		height: 937,
		alt: "Summervilla photo 6",
	},
	{
		src: "/summervilla-bg-7.png",
		width: 1023,
		height: 1537,
		alt: "Summervilla generated photo 7",
	},
	{
		src: "/summervilla-bg-8.png",
		width: 1023,
		height: 1537,
		alt: "Summervilla generated photo 8",
	},
];

let result: RsvpResult | null = null;
let submitted: Record<string, string> = {};

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	submitted = Object.fromEntries(
		[...formData.entries()].filter(([k]) => k !== "password"),
	) as Record<string, string>;

	const honoBody = new URLSearchParams();
	for (const [k, v] of formData.entries()) {
		honoBody.append(k, typeof v === "string" ? v : "");
	}

	const honoReq = new Request(new URL("/rsvp", Astro.url), {
		method: "POST",
		headers: { "content-type": "application/x-www-form-urlencoded" },
		body: honoBody.toString(),
	});

	const res = await app.fetch(
		honoReq,
		Astro.locals.runtime.env,
		Astro.locals.runtime.ctx,
	);
	result = (await res.json()) as RsvpResult;
}

const fieldErrors =
	result && !result.ok && result.error === "validation" ? result.fields : {};
const passwordError = result && !result.ok && result.error === "password";
const duplicateError = result && !result.ok && result.error === "duplicate";
const serverError = result && !result.ok && result.error === "server";
const success = result?.ok === true;
const cardFlipped = result !== null;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="noindex" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>Summervilla RSVP</title>
		<style>
			:root {
				--paper: #ffffff;
				--ink: #28241f;
				--muted: #8f867b;
				--line: rgba(81, 70, 58, 0.24);
				--line-active: rgba(81, 70, 58, 0.46);
				--surface: #ffffff;
				--button: #5f564c;
				--shadow: 0 28px 80px rgba(67, 58, 49, 0.13);
				--font-sans: Arial, Helvetica, sans-serif;
			}

			* {
				box-sizing: border-box;
			}

			html {
				background: var(--paper);
				color: var(--ink);
				font-family: var(--font-sans);
				text-rendering: geometricPrecision;
			}

			body {
				margin: 0;
				min-height: 100dvh;
				background: var(--paper);
				color: var(--ink);
				overflow-x: hidden;
			}

			button,
			input,
			textarea {
				font: inherit;
			}

			button {
				color: inherit;
			}

			.sr-only {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				white-space: nowrap;
				border: 0;
			}

			.scene {
				position: relative;
				min-height: 100svh;
				display: grid;
				place-items: center;
				padding: clamp(2rem, 5vw, 4rem) 1rem;
				overflow: hidden;
				isolation: isolate;
			}

			.scene::before {
				content: "";
				position: absolute;
				inset: 10% 15%;
				z-index: 0;
				background: radial-gradient(
					ellipse at center,
					rgba(83, 73, 62, 0.055),
					transparent 68%
				);
				filter: blur(35px);
				opacity: 0.55;
			}

			.scene-brand {
				position: absolute;
				left: 50%;
				top: 49%;
				z-index: 0;
				width: 100vw;
				transform: translate(-50%, -50%);
				color: rgba(81, 70, 58, 0.1);
				font-size: clamp(4.6rem, 13.2vw, 14.25rem);
				font-weight: 400;
				line-height: 0.76;
				letter-spacing: 0;
				text-align: center;
				text-transform: uppercase;
				white-space: nowrap;
				pointer-events: none;
				user-select: none;
			}

			.float-tile {
				position: absolute;
				z-index: 1;
				margin: 0;
				border-radius: clamp(1.1rem, 2vw, 1.9rem);
				overflow: hidden;
				background: var(--paper);
				box-shadow: 0 18px 55px rgba(67, 58, 49, 0.08);
				opacity: 0.76;
			}

			.float-tile img {
				display: block;
				width: 100%;
				height: auto;
				filter: saturate(0.9) contrast(0.96);
			}

			.tile-1 {
				top: 4vh;
				left: 4vw;
				width: clamp(7.5rem, 10vw, 12rem);
				opacity: 0.32;
			}

			.tile-2 {
				top: 5vh;
				left: 29vw;
				width: clamp(6.2rem, 7.8vw, 9rem);
				opacity: 0.42;
			}

			.tile-3 {
				top: 10vh;
				right: 4vw;
				width: clamp(7.5rem, 10vw, 12rem);
				opacity: 0.5;
			}

			.tile-4 {
				left: 6vw;
				bottom: 8vh;
				width: clamp(7.5rem, 10vw, 12rem);
				opacity: 0.42;
			}

			.tile-5 {
				right: 5vw;
				top: 43vh;
				width: clamp(8rem, 11vw, 13rem);
				opacity: 0.5;
			}

			.tile-6 {
				right: 29vw;
				bottom: -4rem;
				width: clamp(6.2rem, 7.8vw, 9rem);
				opacity: 0.44;
			}

			.tile-7 {
				left: 5vw;
				top: 42vh;
				width: clamp(7.5rem, 10vw, 12rem);
				opacity: 0.45;
			}

			.tile-8 {
				right: 8vw;
				bottom: 8vh;
				width: clamp(6.2rem, 7.8vw, 9rem);
				opacity: 0.44;
			}

			.card-shell {
				position: relative;
				z-index: 2;
				width: min(82vw, 960px);
				display: grid;
				justify-items: center;
			}

			.flip-card {
				position: relative;
				width: 100%;
				aspect-ratio: 1672 / 941;
				perspective: 1800px;
				filter: drop-shadow(var(--shadow));
			}

			.flip-inner {
				position: absolute;
				inset: 0;
				transform-style: preserve-3d;
				transition: transform 750ms cubic-bezier(0.22, 0.61, 0.36, 1);
			}

			.flip-card.is-flipped .flip-inner {
				transform: rotateY(180deg);
			}

			.card-face {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				margin: 0;
				padding: 0;
				border: 0;
				border-radius: 0;
				background: var(--paper);
				color: var(--ink);
				backface-visibility: hidden;
				-webkit-backface-visibility: hidden;
				overflow: hidden;
			}

			.card-face--front {
				cursor: pointer;
				display: grid;
				padding: clamp(0.9rem, 2vw, 1.45rem);
				appearance: none;
				background: #17130f;
				isolation: isolate;
				text-align: left;
			}

			.front-bg {
				position: absolute;
				inset: 0;
				z-index: 0;
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: 50% 36%;
				filter: saturate(1.02) contrast(1) brightness(1.02);
			}

			.front-copy {
				position: relative;
				z-index: 2;
				display: grid;
				align-content: end;
				gap: 0.38rem;
				width: max-content;
				height: 100%;
				min-width: 0;
				padding: clamp(0.15rem, 0.8vw, 0.45rem) 0;
			}

			.front-meta {
				color: rgba(255, 250, 240, 0.84);
				font-size: clamp(0.58rem, 0.8vw, 0.72rem);
				font-weight: 600;
				line-height: 1.15;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}

			.front-meta {
				display: grid;
				gap: 0.38rem;
				letter-spacing: 0.1em;
			}

			.card-face--back {
				background: var(--surface);
				box-shadow: inset 0 0 0 1px rgba(81, 70, 58, 0.055);
				transform: rotateY(180deg);
				overflow: auto;
				padding: clamp(1.1rem, 2.15vw, 1.8rem);
				cursor: pointer;
			}

			.rsvp-form,
			.rsvp-form *,
			button[type="submit"] {
				cursor: auto;
			}

			.reply {
				display: grid;
				grid-template-columns: minmax(0, 30rem);
				gap: clamp(1.15rem, 2.4vw, 1.75rem);
				align-content: center;
				justify-content: center;
				min-height: 100%;
				text-align: center;
			}

			.reply-title {
				margin: 0;
				font-size: clamp(2.1rem, 4.4vw, 4rem);
				font-weight: 400;
				line-height: 0.9;
				letter-spacing: 0;
				color: #39342e;
			}

			.reply-copy {
				max-width: 14rem;
				margin: 0.95rem auto 0;
				color: var(--muted);
				font-size: 0.86rem;
				font-weight: 500;
				line-height: 1.25;
				letter-spacing: 0;
			}

			button[type="submit"]:hover {
				background: #4d463e;
				color: var(--paper);
			}

			.rsvp-form,
			.fields {
				display: grid;
			}

			.rsvp-form {
				gap: 0.8rem;
				justify-items: center;
			}

			.fields {
				width: min(100%, 28rem);
				grid-template-columns: 1fr;
				gap: 0.86rem clamp(1rem, 2vw, 1.55rem);
				text-align: left;
			}

			.field {
				display: grid;
				gap: 0.25rem;
				margin: 0;
				min-width: 0;
			}

			.field--wide,
			.alert,
			.submit-row {
				grid-column: 1 / -1;
			}

			label,
			legend {
				color: var(--muted);
				font-size: 0.58rem;
				font-weight: 650;
				line-height: 1;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			input[type="text"],
			input[type="email"],
			input[type="tel"],
			input[type="number"],
			input[type="password"],
			textarea {
				width: 100%;
				border: 0;
				border-bottom: 1px solid var(--line);
				border-radius: 0;
				background: transparent;
				color: var(--ink);
				padding: 0.2rem 0 0.4rem;
				font-size: clamp(0.95rem, 1.25vw, 1.05rem);
				font-weight: 450;
				line-height: 1.25;
				letter-spacing: 0;
				appearance: none;
				transition:
					border-color 160ms ease,
					background-color 160ms ease,
					color 160ms ease;
			}

			input:focus,
			textarea:focus,
			button[type="submit"]:focus-visible,
			.card-face--front:focus-visible {
				outline: none;
			}

			input:focus,
			textarea:focus {
				border-bottom-color: var(--line-active);
				background: rgba(112, 97, 81, 0.025);
			}

			textarea {
				min-height: 3.8rem;
				resize: vertical;
			}

			fieldset {
				border: 0;
				padding: 0;
			}

			.radios {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 1.05rem;
				min-height: 1.9rem;
				align-items: center;
				border-bottom: 1px solid var(--line);
				transition: border-color 160ms ease;
			}

			.radios:focus-within {
				border-bottom-color: var(--line-active);
			}

			.radio {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				color: #3f3932;
				font-size: clamp(0.95rem, 1.25vw, 1.05rem);
				font-weight: 500;
				line-height: 1.1;
				text-transform: none;
				letter-spacing: 0;
			}

			.radio input {
				width: 0.86rem;
				height: 0.86rem;
				margin: 0;
				border: 1px solid rgba(81, 70, 58, 0.35);
				border-radius: 999px;
				background: transparent;
				appearance: none;
				box-shadow: inset 0 0 0 3px var(--surface);
				transition:
					background-color 150ms ease,
					border-color 150ms ease;
			}

			.radio input:checked {
				border-color: rgba(81, 70, 58, 0.42);
				background: #81766b;
			}

			.radio input:focus,
			.radio input:focus-visible {
				outline: none;
			}

			.alert {
				margin: 0;
				padding: 0.65rem 0;
				border-top: 1px solid rgba(130, 88, 68, 0.22);
				border-bottom: 1px solid rgba(130, 88, 68, 0.22);
				color: #7b5443;
				font-size: 0.9rem;
				font-weight: 550;
				line-height: 1.25;
			}

			.error {
				margin: 0.05rem 0 0;
				color: var(--muted);
				font-size: 0.72rem;
				font-weight: 500;
				line-height: 1.25;
			}

			.submit-row {
				display: grid;
				justify-items: center;
				margin-top: 0.1rem;
			}

			button[type="submit"] {
				min-height: 2.25rem;
				border: 0;
				border-radius: 999px;
				background: var(--button);
				color: var(--paper);
				padding: 0.58rem 1rem 0.62rem;
				font-size: 0.72rem;
				font-weight: 650;
				line-height: 1;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				cursor: pointer;
				transition:
					background-color 160ms ease,
					color 160ms ease,
					transform 160ms ease;
			}

			button[type="submit"]:active {
				transform: translateY(1px);
			}

			.success {
				display: grid;
				gap: 0.7rem;
				border-top: 1px solid var(--line);
				border-bottom: 1px solid var(--line);
				padding: 1.1rem 0 1.2rem;
			}

			.success-title {
				margin: 0;
				font-size: clamp(2rem, 4vw, 3.65rem);
				font-weight: 400;
				line-height: 0.9;
				letter-spacing: 0;
			}

			.success-sub {
				max-width: 25rem;
				margin: 0;
				color: var(--muted);
				font-size: clamp(0.9rem, 1.25vw, 1.02rem);
				font-weight: 500;
				line-height: 1.25;
			}

			@media (max-width: 820px) {
				.scene {
					padding: 1.4rem 0.65rem;
				}

				.float-tile {
					opacity: 0.36;
				}

				.tile-2,
				.tile-6,
				.tile-8 {
					display: none;
				}

				.card-shell {
					width: min(92vw, 680px);
				}

				.scene-brand {
					font-size: clamp(3.2rem, 13vw, 6.4rem);
				}
			}

			@media (max-width: 560px) {
				.scene {
					min-height: 100dvh;
					place-items: center;
					padding: 1rem 0.55rem;
				}

				.card-shell {
					width: min(92vw, 430px);
				}

				.flip-card {
					aspect-ratio: 1672 / 941;
				}

				.card-face--front {
					padding: 0.62rem;
				}

				.front-copy {
					gap: 0.45rem;
				}

				.front-meta {
					font-size: 0.47rem;
					letter-spacing: 0.08em;
				}

				.scene-brand {
					top: 57%;
					font-size: clamp(2.45rem, 11.2vw, 3.2rem);
				}

				.float-tile {
					width: auto;
					opacity: 0.3;
				}

				.reply {
					grid-template-columns: 1fr;
					gap: 0.42rem;
					align-content: center;
				}

				.card-face--back {
					overflow: hidden;
					padding: 0.55rem 0.65rem;
				}

				.rsvp-form {
					gap: 0.32rem;
				}

				.reply-copy {
					display: none;
				}

				.reply-title {
					font-size: clamp(1.65rem, 8.5vw, 2.05rem);
				}

				.fields {
					width: min(100%, 22rem);
					grid-template-columns: repeat(2, minmax(0, 1fr));
					gap: 0.36rem 0.58rem;
				}

				.fields .field--wide {
					grid-column: auto;
				}

				.alert,
				.submit-row {
					grid-column: 1 / -1;
				}

				label,
				legend {
					font-size: 0.43rem;
					letter-spacing: 0.06em;
				}

				input[type="text"],
				input[type="email"],
				input[type="tel"],
				input[type="number"],
				input[type="password"],
				textarea {
					padding: 0.08rem 0 0.22rem;
					font-size: 0.74rem;
					line-height: 1.12;
				}

				.field {
					gap: 0.14rem;
				}

				.error {
					margin-top: 0;
					font-size: 0.5rem;
					line-height: 1.05;
				}

				.alert {
					padding: 0.2rem 0;
					font-size: 0.58rem;
					line-height: 1.05;
				}

				.submit-row {
					margin-top: 0;
				}

				button[type="submit"] {
					min-height: 1.7rem;
					padding: 0.44rem 0.7rem 0.46rem;
					font-size: 0.55rem;
				}

				.tile-1 {
					top: 3vh;
					left: 0.45rem;
					width: 4.35rem;
				}

				.tile-2 {
					display: block;
					top: 22vh;
					left: 1.75rem;
					width: 4.15rem;
					opacity: 0.22;
				}

				.tile-3 {
					top: 5vh;
					right: 0.6rem;
					width: 4.35rem;
				}

				.tile-4 {
					left: 1.35rem;
					bottom: 7vh;
					width: 4.8rem;
				}

				.tile-5 {
					right: 0.65rem;
					top: 48vh;
					width: 5.1rem;
				}

				.tile-6 {
					display: block;
					right: 38vw;
					bottom: 2vh;
					width: 4.1rem;
					opacity: 0.22;
				}

				.tile-7 {
					display: block;
					left: 0.55rem;
					top: 43vh;
					width: 5rem;
					opacity: 0.22;
				}

				.tile-8 {
					display: block;
					right: 1.25rem;
					bottom: 6vh;
					width: 4.7rem;
					opacity: 0.24;
				}
			}
		</style>
	</head>

	<body>
		<main class="scene">
			<h1 class="sr-only">Summervilla RSVP</h1>
			<div class="scene-brand" aria-hidden="true">Summer villa</div>

			{
				floatingPhotos.map((photo, index) => (
					<figure class:list={["float-tile", `tile-${index + 1}`]}>
						<img
							src={photo.src}
							width={photo.width}
							height={photo.height}
							alt=""
							loading={index < 3 ? "eager" : "lazy"}
							decoding="async"
						/>
					</figure>
				))
			}

			<section class="card-shell" aria-label="Summervilla RSVP card">
				<div
					class:list={["flip-card", { "is-flipped": cardFlipped }]}
					id="rsvp-card"
				>
					<div class="flip-inner">
						<button
							type="button"
							class="card-face card-face--front"
							id="flip-open"
							aria-label="Open RSVP form"
						>
							<img
								class="front-bg"
								src="/dc38bb96-07db-4d0f-9e28-eb74625463ad_2075x3130.jpg"
								width="2075"
								height="3130"
								alt=""
								loading="eager"
								decoding="async"
								aria-hidden="true"
							/>
							<div class="front-copy" aria-hidden="true">
								<div class="front-meta">
									<span>RSVP</span>
									<span>Invite only</span>
								</div>
							</div>
						</button>

						<div class="card-face card-face--back">
							<section class="reply" aria-labelledby="reply-title">
								<div>
									<h2 class="reply-title" id="reply-title">RSVP</h2>
									<p class="reply-copy">Invite only.</p>
								</div>

								{success ? (
									<div class="success" role="status">
										<p class="success-sub">
											Reply on the way. See you in Summer villa.
										</p>
									</div>
								) : (
									<form class="rsvp-form" method="POST" novalidate>
										<input
											type="hidden"
											name="attending"
											value={submitted.attending ?? "yes"}
										/>
										<input
											type="hidden"
											name="plus_one"
											value={submitted.plus_one ?? "0"}
										/>
										<div class="fields">
											{passwordError && (
												<p class="alert">Wrong password. Try again.</p>
											)}
											{duplicateError && (
												<p class="alert">That email has already RSVP'd.</p>
											)}
											{serverError && (
												<p class="alert">Something went wrong. Please try again.</p>
											)}

											<label class="field">
												Name
												<input
													type="text"
													name="name"
													required
													maxlength="120"
													autocomplete="name"
													value={submitted.name ?? ""}
												/>
												{fieldErrors.name && (
													<p class="error">{fieldErrors.name}</p>
												)}
											</label>

											<label class="field">
												Phone
												<input
													type="tel"
													name="phone"
													required
													maxlength="40"
													autocomplete="tel"
													value={submitted.phone ?? ""}
												/>
												{fieldErrors.phone && (
													<p class="error">{fieldErrors.phone}</p>
												)}
											</label>

											<label class="field field--wide">
												Email
												<input
													type="email"
													name="email"
													required
													maxlength="200"
													autocomplete="email"
													value={submitted.email ?? ""}
												/>
												{fieldErrors.email && (
													<p class="error">{fieldErrors.email}</p>
												)}
											</label>

											<label class="field field--wide">
												Password
												<input
													type="password"
													name="password"
													required
													autocomplete="off"
													maxlength="200"
												/>
												{fieldErrors.password && (
													<p class="error">{fieldErrors.password}</p>
												)}
											</label>

											<div class="submit-row">
												<button type="submit">Send Reply</button>
											</div>
										</div>
									</form>
								)}
							</section>
						</div>
					</div>
				</div>

			</section>
		</main>

		<script>
			const card = document.getElementById("rsvp-card");
			const open = document.getElementById("flip-open");

			open?.addEventListener("click", () => {
				card?.classList.add("is-flipped");
			});

			card?.addEventListener("click", (event) => {
				if (!card.classList.contains("is-flipped")) return;
				const target = event.target;

				if (!(target instanceof Element)) return;
				if (target.closest("form, input, textarea, button, label, fieldset")) {
					return;
				}

				card.classList.remove("is-flipped");
			});

			document.addEventListener("keydown", (event) => {
				if (event.key !== "Escape" || !card?.classList.contains("is-flipped")) {
					return;
				}

				card.classList.remove("is-flipped");
			});
		</script>
	</body>
</html>
