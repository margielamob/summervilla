---
import app, { type RsvpResult } from "../server/api";

export const prerender = false;

let result: RsvpResult | null = null;
let submitted: Record<string, string> = {};

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	submitted = Object.fromEntries(
		[...formData.entries()].filter(([k]) => k !== "password"),
	) as Record<string, string>;

	const honoBody = new URLSearchParams();
	for (const [k, v] of formData.entries()) {
		honoBody.append(k, typeof v === "string" ? v : "");
	}

	const honoReq = new Request(new URL("/rsvp", Astro.url), {
		method: "POST",
		headers: { "content-type": "application/x-www-form-urlencoded" },
		body: honoBody.toString(),
	});

	const res = await app.fetch(
		honoReq,
		Astro.locals.runtime.env,
		Astro.locals.runtime.ctx,
	);
	result = (await res.json()) as RsvpResult;
}

const fieldErrors = result && !result.ok && result.error === "validation"
	? result.fields
	: {};
const passwordError = result && !result.ok && result.error === "password";
const duplicateError = result && !result.ok && result.error === "duplicate";
const serverError = result && !result.ok && result.error === "server";
const success = result?.ok === true;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="noindex" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>RSVP</title>
		<style>
			body {
				font-family:
					ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
				margin: 0;
				background: #fff;
				color: #111;
				display: grid;
				place-items: center;
				min-height: 100dvh;
				padding: 2rem 1rem;
			}
			main {
				width: 100%;
				max-width: 28rem;
			}
			h1 {
				font-size: 1.5rem;
				margin: 0 0 1.5rem;
			}
			form {
				display: grid;
				gap: 1rem;
			}
			label {
				display: grid;
				gap: 0.25rem;
				font-size: 0.875rem;
			}
			input,
			textarea,
			select {
				font: inherit;
				padding: 0.5rem 0.625rem;
				border: 1px solid #d1d5db;
				border-radius: 0.375rem;
				background: #fff;
				color: inherit;
			}
			input:focus,
			textarea:focus,
			select:focus {
				outline: 2px solid #111;
				outline-offset: -1px;
			}
			textarea {
				min-height: 5rem;
				resize: vertical;
			}
			fieldset {
				border: 0;
				padding: 0;
				margin: 0;
				display: flex;
				gap: 1rem;
				font-size: 0.875rem;
			}
			fieldset legend {
				margin-bottom: 0.25rem;
			}
			button {
				font: inherit;
				padding: 0.625rem 1rem;
				background: #111;
				color: #fff;
				border: 0;
				border-radius: 0.375rem;
				cursor: pointer;
			}
			button:hover {
				background: #000;
			}
			.error {
				color: #b00020;
				font-size: 0.8125rem;
				margin: 0;
			}
			.banner {
				padding: 0.625rem 0.75rem;
				border: 1px solid #b00020;
				background: #fff5f5;
				color: #b00020;
				border-radius: 0.375rem;
				font-size: 0.875rem;
				margin-bottom: 1rem;
			}
			.success {
				padding: 1rem;
				border: 1px solid #d1d5db;
				border-radius: 0.375rem;
			}
		</style>
	</head>
	<body>
		<main>
			<h1>RSVP</h1>

			{success ? (
				<div class="success">
					<p><strong>Thanks — your RSVP is recorded.</strong></p>
				</div>
			) : (
				<>
					{passwordError && (
						<p class="banner">Wrong password. Try again.</p>
					)}
					{duplicateError && (
						<p class="banner">That email has already RSVP'd.</p>
					)}
					{serverError && (
						<p class="banner">Something went wrong. Please try again.</p>
					)}

					<form method="POST" novalidate>
						<label>
							Name
							<input
								type="text"
								name="name"
								required
								maxlength="120"
								autocomplete="name"
								value={submitted.name ?? ""}
							/>
							{fieldErrors.name && <p class="error">{fieldErrors.name}</p>}
						</label>

						<label>
							Email
							<input
								type="email"
								name="email"
								required
								maxlength="200"
								autocomplete="email"
								value={submitted.email ?? ""}
							/>
							{fieldErrors.email && <p class="error">{fieldErrors.email}</p>}
						</label>

						<label>
							Phone
							<input
								type="tel"
								name="phone"
								required
								maxlength="40"
								autocomplete="tel"
								value={submitted.phone ?? ""}
							/>
							{fieldErrors.phone && <p class="error">{fieldErrors.phone}</p>}
						</label>

						<fieldset>
							<legend>Attending?</legend>
							<label style="flex-direction: row; align-items: center; gap: 0.375rem;">
								<input
									type="radio"
									name="attending"
									value="yes"
									required
									checked={submitted.attending !== "no"}
								/>
								Yes
							</label>
							<label style="flex-direction: row; align-items: center; gap: 0.375rem;">
								<input
									type="radio"
									name="attending"
									value="no"
									checked={submitted.attending === "no"}
								/>
								No
							</label>
						</fieldset>
						{fieldErrors.attending && (
							<p class="error">{fieldErrors.attending}</p>
						)}

						<label>
							Bringing a +1? (0–5)
							<input
								type="number"
								name="plus_one"
								min="0"
								max="5"
								value={submitted.plus_one ?? "0"}
							/>
							{fieldErrors.plus_one && (
								<p class="error">{fieldErrors.plus_one}</p>
							)}
						</label>

						<label>
							Message (optional)
							<textarea name="message" maxlength="2000">{submitted.message ?? ""}</textarea>
							{fieldErrors.message && (
								<p class="error">{fieldErrors.message}</p>
							)}
						</label>

						<label>
							Password
							<input type="password" name="password" required autocomplete="off" />
							{fieldErrors.password && (
								<p class="error">{fieldErrors.password}</p>
							)}
						</label>

						<button type="submit">Submit RSVP</button>
					</form>
				</>
			)}
		</main>
	</body>
</html>
