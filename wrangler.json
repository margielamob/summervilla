{
	"name": "summervilla",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "summervilla-rsvp",
			"database_id": "REPLACE_WITH_UUID_FROM_WRANGLER_D1_CREATE"
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
